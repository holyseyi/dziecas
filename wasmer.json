{
  "runtime": "php",
  "version": "8.3",
  "build": {
    "builder": "wasmer/wasmer-php",
    "args": {
      "PHP_VERSION": "8.3"
    }
  },
  "deploy": {
    "startCommand": "php -S 0.0.0.0:8000 -t public",
    "httpPort": 8000,
    "documentRoot": "public",
    "env": {
      "APP_ENV": "production",
      "APP_DEBUG": "false"
    }
  }
}
